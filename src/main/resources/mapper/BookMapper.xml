<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.bookms.mapper.BookMapper">

    <select id="findAll" resultType="Book">
        select * from book
    </select>

    <insert id="add" parameterType="Book">
        insert into book(name,author,publish,price)
        values(#{name},#{author},#{publish},#{price})
    </insert>

    <delete id="delete" parameterType="int">
        delete from book where id=#{id}
    </delete>

    <select id="findById" parameterType="int" resultType="Book">
        select * from book where id=#{id}
    </select>

    <update id="update" parameterType="Book">
        update book set name=#{name},author=#{author},publish=#{publish},price=#{price}
        where id=#{id}
    </update>
</mapper>